rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images are public-read for invoice sharing.
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
